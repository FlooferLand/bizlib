!version 2
set faz
set rae

rae 166 {
	flow 1.6
	rotate "Jaw" x:-25.5
}

any 101 {
	flow ease-in 0.8
	rotate "Head" x:-25
	move "Head" x:5.3
    type servo
}

any 69 {
	flow 1.0
	anim "body_lean"
}

rae 67, faz 67 {
	flow 1.1
	anim "guitar_tilt"
}

faz 133, rae 113 {
    flow 0.6
    move "LeftEye" x:1
    move "RightEye" x:1
    type effect
}

faz 14td, rae 13td {
    flow 0.6
    move "LeftEye" x:-1
    move "RightEye" x:-1
}

rae 96td {
    flow 0.6
    move "Mouth" x:-1
    type servo
    hold yes
}
